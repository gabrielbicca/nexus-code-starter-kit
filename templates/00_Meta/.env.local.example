# Exemplo de variáveis de ambiente — copie para .env.local e preencha.
# NUNCA commite .env.local (deve estar no .gitignore).
# Mantenha este arquivo versionado com chaves reais e valores fake/placeholder.

# --- App ---
NODE_ENV=development
PORT=3000

# --- Banco / Supabase (exemplo — ajuste ao stack do projeto) ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-placeholder>
SUPABASE_SERVICE_ROLE_KEY=<service-role-placeholder>

# --- Outros serviços ---
# API_KEY=<placeholder>
